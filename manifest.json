{
  "manifest_version": 3,
  "name": "Winday Notetaker",
  "version": "1.1.0",
  "minimum_chrome_version": "116",
  "description": "Records your Google Meet calls, transcribes them with Deepgram, summarizes them with Gemini, and pushes the notes to the Winday CRM + Notion.",
  "action": {
    "default_title": "Winday Notetaker",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "offscreen",
    "tabCapture",
    "activeTab",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "https://gagfovgnuttmngnhqzwd.supabase.co/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options/options.html",
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["https://meet.google.com/*"]
    }
  ]
}
